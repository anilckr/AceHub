generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum OrderProvider {
  IYZICO
  SHOPIER
}

enum OrderStatus {
  INIT
  PAID
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model License {
  id           String        @id @default(cuid())
  code         String        @unique
  durationDays Int
  startsAt     DateTime      @default(now())
  expiresAt    DateTime
  status       LicenseStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Order {
  id        String        @id @default(cuid())
  provider  OrderProvider
  status    OrderStatus   @default(INIT)
  amount    Int
  currency  String        @default("TRY")
  email     String?
  licenseId String?
  rawInit   Json?
  rawResult Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
